# Emsalist Environment Configuration
# Copy to backend/.env for local development

# Environment (development | production | test)
EMSALIST_ENVIRONMENT=development

# Logging
EMSALIST_LOG_LEVEL=DEBUG
EMSALIST_LOG_FORMAT=text
EMSALIST_LOG_SERVICE_NAME=emsalist-api

# Database (empty defaults to SQLite at ./case_store/emsalist.db)
DATABASE_URL=
# PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://emsalist:password@localhost:5432/emsalist

# Authentication
AUTH_MODE=local
JWT_SECRET_KEY=
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_MINUTES=30
# JWT_REFRESH_TOKEN_DAYS=7

# CORS and Trusted Hosts (comma-separated, required in production)
ALLOWED_HOSTS=
CORS_ALLOW_ORIGINS=

# File Upload (default: 15 MB)
# EMSALIST_MAX_UPLOAD_SIZE=15728640

# Storage
# EMSALIST_STORAGE_ROOT=backend/document_store

# Backup
BACKUP_ENCRYPTION_ENABLED=false
BACKUP_ENCRYPTION_KEY=

# AI (optional)
GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=30

# Metrics
# EMSALIST_METRICS_ENABLED=true

# Debug
EMSALIST_DEBUG=false

# Apple Sign-In (disabled by default, enable for production)
APPLE_SIGN_IN_ENABLED=false
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
APPLE_SUBJECT_PEPPER=
# APPLE_TOKEN_ENDPOINT=https://appleid.apple.com/auth/token
# APPLE_JWKS_URL=https://appleid.apple.com/auth/keys
# APPLE_ISSUER=https://appleid.apple.com
# APPLE_HTTP_TIMEOUT_SECONDS=5
# APPLE_JWKS_CACHE_SECONDS=3600
# APPLE_LINK_TICKET_SECONDS=300
