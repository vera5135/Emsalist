# Environment
EMSALIST_ENVIRONMENT=development   # development | production | test
EMSALIST_LOG_LEVEL=DEBUG           # DEBUG | INFO | WARNING | ERROR
EMSALIST_LOG_FORMAT=text           # json | text (production defaults to json)
EMSALIST_LOG_SERVICE_NAME=emsalist-api

GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=30
