"""Build Yargıtay-friendly search query alternatives."""

from app.models.case_models import SearchBuildRequest, SearchBuildResponse


class RuleBasedSearchBuilder:
    """Create focused queries from the topic, keywords and case text."""

    def build(self, request: SearchBuildRequest) -> SearchBuildResponse:
        topic = request.legal_topic.strip()
        keywords = request.legal_keywords
        case_lower = request.case_text.casefold()
        topic_lower = topic.casefold()

        queries: list[str] = []
        self._add(queries, topic)

        if "nafaka" in topic_lower or "nafaka" in case_lower:
            self._add(queries, "yoksulluk nafakası kaldırılması ekonomik durum değişikliği")
            self._add(queries, "nafaka indirimi hakkaniyet gelir azalması")
            self._add(queries, "TMK 176 nafakanın kaldırılması")
            self._add(queries, "TMK 331 nafaka miktarının yeniden belirlenmesi")

            if any(term in case_lower for term in ("işe girdi", "çalışmaya başladı", "maaş")):
                self._add(queries, "nafaka alacaklısının çalışmaya başlaması nafakanın kaldırılması")
            if any(term in case_lower for term in ("yeniden evlendi", "evlendi")):
                self._add(queries, "nafaka alacaklısının yeniden evlenmesi nafakanın sona ermesi")
            if any(term in case_lower for term in ("gelir azaldı", "işsiz", "emekli")):
                self._add(queries, "nafaka yükümlüsünün gelirinin azalması nafaka indirimi")

        if any(term in topic_lower or term in case_lower for term in ("kira", "kiracı", "tahliye", "kiralanan")):
            self._add(queries, "ihtiyaç nedeniyle tahliye gerçek samimi zorunlu ihtiyaç")
            self._add(queries, "TBK 350 konut ihtiyacı nedeniyle tahliye")
            self._add(queries, "kiralananın tahliyesi ihtiyaç sahibi başka konut")
            self._add(queries, "kira sözleşmesi dönem sonunda ihtiyaç nedeniyle tahliye")

        if any(term in topic_lower or term in case_lower for term in ("işçi", "kıdem", "ihbar", "fazla mesai", "işçilik")):
            self._add(queries, "işçilik alacakları kıdem ihbar fazla mesai")
            self._add(queries, "fazla çalışma ispat tanık bordro")
            self._add(queries, "arabuluculuk son tutanağı işçilik alacağı dava şartı")

        if any(term in topic_lower or term in case_lower for term in ("icra", "itiraz", "takip", "ödeme emri")):
            self._add(queries, "itirazın iptali alacağın varlığı icra inkar tazminatı")
            self._add(queries, "İİK 67 itirazın iptali likit alacak")
            self._add(queries, "ilamsız icra takibi borca itirazın iptali")

        if any(term in topic_lower or term in case_lower for term in ("ayıp", "gizli ayıp", "ayıplı araç", "araç satışı", "ekspertiz", "ağır hasar", "tramer")):
            self._add(queries, "ayıplı araç satışı gizli ayıp sözleşmeden dönme")
            self._add(queries, "ikinci el araç gizli ayıp bedel indirimi")
            self._add(queries, "araç satışında ağır hasar kaydı gizli ayıp")
            self._add(queries, "TBK 219 TBK 227 ayıba karşı tekeffül araç")
            self._add(queries, "satıcının ayıba karşı sorumluluğu ikinci el araç")

        for index in range(0, min(len(keywords), 6), 2):
            pair = keywords[index : index + 2]
            self._add(queries, " ".join([topic, *pair]))

        return SearchBuildResponse(queries=queries[:10])

    @staticmethod
    def _add(queries: list[str], query: str) -> None:
        cleaned = " ".join(query.split())
        if cleaned and cleaned.casefold() not in {item.casefold() for item in queries}:
            queries.append(cleaned)


search_builder = RuleBasedSearchBuilder()
