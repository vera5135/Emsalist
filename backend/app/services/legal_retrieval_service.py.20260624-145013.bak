}


class LegalRetrievalService:
    """Search persistent Legal Brain memory and prepare case-oriented sources."""

    def search(
        self,
        *,
        query: str,
        practice_area: str | None,
        max_results: int,
    ) -> LegalBrainSearchResponse:
        query_embedding = legal_embedding_service.embed_text(query)
        candidate_limit = min(max(max_results * 5, max_results), 100)
        records = book_memory_service.search_chunks(
            query=query,
            query_embedding=query_embedding,
            practice_area=practice_area,
            max_results=candidate_limit,
        )
        results = [self._to_search_result(query=query, record=record) for record in records]
        results.sort(key=lambda result: result.relevance_score, reverse=True)
        results = results[:max_results]
        warnings: list[str] = []
        if not results:
            warnings.append("Legal Brain içinde arama ile eşleşen kaynak bulunamadı.")
        elif not any(result.is_directly_relevant for result in results):
            warnings.append("Arama sonucu bulundu ancak doğrudan uyuşmazlıkla ilgili kaynak saptanamadı.")
        return LegalBrainSearchResponse(results=results, warnings=warnings)

    def retrieve_for_case(
        self,
        *,
        case_text: str,
        practice_area: str | None,
        max_sources: int,
        legal_brain_query: str | None = None,
        blocked_topics: list[str] | None = None,
    ) -> LegalBrainRetrieveForCaseResponse:
        analysis = case_analyzer.analyze(case_text)
        detected_area = practice_area or self._default_practice_area(analysis.legal_topic)
        query = legal_brain_query or " ".join([case_text, analysis.legal_topic, *analysis.legal_keywords])
        blocked_terms = [self._plain(term) for term in (blocked_topics or []) if term]
        search_response = self.search(
            query=query,
            practice_area=detected_area,
            max_results=max_sources,
        )
        direct_book_sources = [
            result for result in search_response.results if result.is_directly_relevant and not self._is_blocked_result(result.model_dump(), blocked_terms)
        ][:max_sources]
        doctrine_cards = [
            DoctrineCard(
                topic=card.get("topic", ""),
                principle=card.get("principle", ""),
                related_articles=card.get("related_articles", []),
                practice_note=card.get("practice_note", ""),
                source_label=card.get("source_label", ""),
            )
            for card in book_memory_service.search_doctrine_cards(
                query=query,
                practice_area=detected_area,
                max_results=max_sources,
            )
            if self._card_is_directly_relevant(card) and not self._is_blocked_result(card, blocked_terms)
        ]
        statute_sources = self._statute_sources(case_text=case_text, topic=analysis.legal_topic)
        recommended_arguments = legal_argument_builder.recommended_arguments(
            case_text=case_text,
            statute_sources=statute_sources,
            book_sources=direct_book_sources,
            doctrine_cards=doctrine_cards,
        )
        warnings: list[str] = []
        if not direct_book_sources:
            warnings.extend(
                search_response.warnings
                or ["Legal Brain içinde bu olayla doğrudan eşleşen kitap veya madde kaynağı bulunamadı."]
            )
        if not doctrine_cards:
            warnings.append("Bu konu için doğrudan ilgili doktrin fişi bulunamadı.")

        return LegalBrainRetrieveForCaseResponse(
            detected_topic=analysis.legal_topic,
            statute_sources=statute_sources,
            book_sources=direct_book_sources,
            doctrine_cards=doctrine_cards,
            recommended_arguments=recommended_arguments,
            warnings=warnings,
        )

    def _to_search_result(self, *, query: str, record: dict) -> LegalBrainSearchResult:
        metadata = record.get("metadata", {})
        citation = legal_argument_builder.citation_label(record)
        analysis = self._score_record(query=query, record=record)
        doctrine_principle = ""
        if analysis["is_directly_relevant"]:
            doctrine_principle = self._matching_doctrine_principle(
                query=query,
                practice_area=metadata.get("practice_area"),
            )
        article_label = self._article_label(metadata)
        return LegalBrainSearchResult(
            source_type=metadata.get("source_type") or "book",
            title=metadata.get("title") or "",
            author=metadata.get("author") or "",
            page_start=int(metadata.get("page_start") or 0),
            page_end=int(metadata.get("page_end") or 0),
            section_title=metadata.get("section_title") or "",
            article=article_label,
            relevance_score=analysis["score"],
            matched_terms=analysis["matched_terms"],
            is_directly_relevant=analysis["is_directly_relevant"],
            relevance_reason=analysis["relevance_reason"],
            chunk_preview=self._preview(record.get("text", "")),
            doctrine_principle=doctrine_principle,
            usable_argument=legal_argument_builder.usable_argument_for_chunk(query=query, record=record),
            citation_label=citation,
        )

    def _score_record(self, *, query: str, record: dict) -> dict[str, Any]:
        metadata = record.get("metadata", {})
        text = str(record.get("text") or "")
        code = str(metadata.get("code") or "").upper()
        article = str(metadata.get("article") or "")
        plain_query = self._plain(query)
        haystack = self._plain(
            " ".join(
                str(value or "")
                for value in (
                    text,
                    metadata.get("title", ""),
                    metadata.get("section_title", ""),
                    metadata.get("article_title", ""),
                    code,
                    article,
                )
            )
        )

        is_nafaka_query = self._is_nafaka_query(plain_query)
        is_vehicle_query = self._is_vehicle_query(plain_query)
        matched_terms = self._matched_terms(haystack, code=code, article=article)
        reasons: list[str] = []
        score = min(int(record.get("relevance_score") or 0), 30)

        article_bonus = self._article_reference_bonus(query=query, code=code, article=article)
        if article_bonus:
            score += article_bonus
            reasons.append("sorgudaki kanun maddesiyle doğrudan eşleşiyor")

        phrase_bonus = 0
        for label, phrase in EXACT_PHRASES:
            if phrase in plain_query and phrase in haystack:
                phrase_bonus += 30
                reasons.append(f"'{label}' ifadesi kaynakta aynen geçiyor")
        score += min(phrase_bonus, 60)

        score += self._meaningful_token_bonus(plain_query, haystack)
        article_priority = 0
        if is_nafaka_query:
            article_priority = self._nafaka_article_priority(code=code, article=article)
        elif is_vehicle_query:
            article_priority = self._vehicle_article_priority(code=code, article=article)
        if article_priority:
            score += article_priority
            topic_label = "ayıplı araç uyuşmazlıklarında" if is_vehicle_query else "nafaka uyuşmazlıklarında"
            reasons.append(f"{code} {article} {topic_label} öncelikli madde")

        concept_terms = self._vehicle_concepts() if is_vehicle_query else self._nafaka_concepts()
        concept_count = sum(1 for concept in concept_terms if concept in haystack)
        if concept_count >= 2:
            score += min(25, concept_count * 6)
            topic_label = "ayıplı araç uyuşmazlığına" if is_vehicle_query else "nafaka uyuşmazlığına"
            reasons.append(f"{topic_label} ilişkin birden fazla kavram birlikte geçiyor")

        has_irrelevant_signal = any(term in haystack for term in IRRELEVANT_AREA_TERMS) or (
            is_vehicle_query and "nafaka" in haystack
        )
        if has_irrelevant_signal:
            score -= 45
            reasons.append("uyuşmazlık alanı dışında kalan aile/eşya/miras gibi alakasız bölüm göstergesi var")

        is_directly_relevant = self._is_directly_relevant(
            code=code,
            article=article,
            is_nafaka_query=is_nafaka_query,
            is_vehicle_query=is_vehicle_query,
            matched_terms=matched_terms,
            has_irrelevant_signal=has_irrelevant_signal,
            haystack=haystack,
        )
        if not is_directly_relevant:
            score = min(score, 45)
        if has_irrelevant_signal:
            score = min(score, 25)

        score = max(0, min(100, round(score)))
        if not reasons:
            topic_label = "ayıplı araç" if is_vehicle_query else "nafaka" if is_nafaka_query else "somut uyuşmazlık"
            reasons.append(f"genel kelime benzerliği dışında güçlü {topic_label} bağlantısı saptanmadı")
        if not is_directly_relevant:
            topic_label = "ayıplı araç" if is_vehicle_query else "nafaka" if is_nafaka_query else "somut"
            reasons.append(f"kaynak somut {topic_label} uyuşmazlığıyla doğrudan bağlantılı görünmüyor")

        return {
            "score": score,
            "matched_terms": matched_terms,
            "is_directly_relevant": is_directly_relevant,
            "relevance_reason": "; ".join(self._dedupe(reasons)),
        }

    @staticmethod
    def _article_reference_bonus(*, query: str, code: str, article: str) -> int:
        if not code or not article:
            return 0
        for query_code, query_article in ARTICLE_REF_RE.findall(query):
            if query_code.upper() == code and query_article == article:
                return 50
        return 0

    @staticmethod
    def _nafaka_article_priority(*, code: str, article: str) -> int:
        if code == "TMK" and article == "176":
            return 45
        if code == "TMK" and article == "175":
            return 35
        if code == "TMK" and article == "4":
            return 30
        if (code == "TMK" and article == "2") or (code == "HMK" and article == "190"):
            return 22
        if code == "TMK" and article.isdigit() and 170 <= int(article) <= 174:
            return 12
        if code == "TMK" and article.isdigit() and 177 <= int(article) <= 190:
            return 8
        return 0

    @staticmethod
    def _vehicle_article_priority(*, code: str, article: str) -> int:
        if code == "TBK" and article in {"219", "223", "227", "229"}:
            return 45
        if code == "TKHK":
            return 36
        if code == "HMK" and article in {"190", "266", "288", "293"}:
            return 24
        return 0

    @staticmethod
    def _nafaka_concepts() -> tuple[str, ...]:
        return ("nafaka", "yoksulluk nafakasi", "mali durum", "hakkaniyet", "odeme gucu", "emekli", "kira")

    @staticmethod
    def _vehicle_concepts() -> tuple[str, ...]:
        return (
            "ayipli arac",
            "gizli ayip",
            "ayiba karsi tekefful",
            "sozlesmeden donme",
            "bedel indirimi",
            "tramer",
            "ekspertiz",
            "servis raporu",
            "noter satis",
            "tbk 219",
            "tbk 223",
            "tbk 227",
            "tbk 229",
            "tkhk",
            "bilirkisi",
        )

    def _meaningful_token_bonus(self, plain_query: str, haystack: str) -> int:
        query_tokens = {
            token
            for token in re.findall(r"[a-z0-9]+", plain_query)
            if len(token) > 2 and token not in GENERIC_QUERY_TOKENS
        }
        text_tokens = set(re.findall(r"[a-z0-9]+", haystack))
        return min(18, len(query_tokens & text_tokens) * 3)

    def _matched_terms(self, haystack: str, *, code: str, article: str) -> list[str]:
        matched: list[str] = []
        for label, term in MATCH_TERMS:
            if term in haystack:
                matched.append(label)
        if code == "TMK" and article == "176" and "TMK 176" not in matched:
            matched.append("TMK 176")
        if code == "TMK" and article == "175" and "TMK 175" not in matched:
            matched.append("TMK 175")
        if code == "TMK" and article == "4" and "hakkaniyet" not in matched:
            matched.append("hakkaniyet")
        if code == "TBK" and article in {"219", "223", "227", "229"}:
            label = f"TBK {article}"
            if label not in matched:
                matched.append(label)
        if code == "TKHK" and "TKHK" not in matched:
            matched.append("TKHK")
        if code == "HMK" and article in {"190", "266"} and "bilirkişi" not in matched:
            matched.append("bilirkişi")
        return self._dedupe(matched)

    @staticmethod
    def _is_nafaka_query(plain_query: str) -> bool:
        return any(
            term in plain_query
            for term in (
                "yoksulluk nafakasi",
                "nafakanin kaldirilmasi",
                "nafakanin indirilmesi",
                "nafaka indirimi",
                "tmk 176",
                "nafaka",
            )
        )

    @staticmethod
    def _is_vehicle_query(plain_query: str) -> bool:
        return any(
            term in plain_query
            for term in (
                "ayipli arac",
                "gizli ayip",
                "arac satisi",
                "ikinci el arac",
                "ekspertiz",
                "tramer",
                "agir hasar",
                "motor arizasi",
                "sozlesmeden donme",
                "bedel indirimi",
                "tbk 219",
                "tbk 223",
                "tbk 227",
                "tbk 229",
            )
        )

    @staticmethod
    def _is_directly_relevant(
        *,
        code: str,
        article: str,
        is_nafaka_query: bool,
        is_vehicle_query: bool,
        matched_terms: list[str],
        has_irrelevant_signal: bool,
        haystack: str,
    ) -> bool:
        if is_vehicle_query:
            if has_irrelevant_signal or code == "TMK":
                return False
            if (code, article) in {("TBK", "219"), ("TBK", "223"), ("TBK", "227"), ("TBK", "229"), ("HMK", "190"), ("HMK", "266")}:
                return True
            if code == "TKHK":
                return True
            direct_terms = {
                "ayıplı araç",
                "gizli ayıp",
                "araç satışı",
                "ikinci el araç",
                "ayıba karşı tekeffül",
                "sözleşmeden dönme",
                "bedel indirimi",
                "TRAMER",
                "ekspertiz raporu",
                "servis raporu",
                "noter satış sözleşmesi",
                "TBK 219",
                "TBK 223",
                "TBK 227",
                "TBK 229",
                "TKHK",
                "bilirkişi",
            }
            return any(term in direct_terms for term in matched_terms) and LegalRetrievalService._has_vehicle_core(haystack)

        if not is_nafaka_query:
            return False
        if has_irrelevant_signal and code != "TMK":
            return False
        if is_nafaka_query and (code, article) in {("TMK", "175"), ("TMK", "176"), ("TMK", "4"), ("TMK", "2"), ("HMK", "190")}:
            return True
        direct_terms = {
            "nafaka",
            "yoksulluk nafakası",
            "nafakanın kaldırılması",
            "nafakanın indirilmesi",
            "TMK 176",
            "TMK 175",
            "hakkaniyet",
            "mali durum",
            "sosyal ve ekonomik durum",
            "ödeme gücü",
        }
        if any(term in direct_terms for term in matched_terms) and not has_irrelevant_signal:
            return True
        return "nafaka" in haystack and not has_irrelevant_signal

    @staticmethod
    def _has_vehicle_core(haystack: str) -> bool:
        return any(
            term in haystack
            for term in (
                "ayipli arac",
                "gizli ayip",
                "arac satisi",
                "ikinci el arac",
                "ayiba karsi tekefful",
                "sozlesmeden donme",
                "bedel indirimi",
                "tramer",
                "ekspertiz",
                "servis raporu",
                "noter satis",
                "tbk 219",
                "tbk 223",
                "tbk 227",
                "tbk 229",
                "tkhk",
            )
        )

    @staticmethod
    def _card_is_directly_relevant(card: dict[str, Any]) -> bool:
        haystack = LegalRetrievalService._plain(
            " ".join(
                str(card.get(key, ""))
                for key in ("topic", "principle", "practice_note", "source_label")
            )
        )
        return any(
            term in haystack
            for term in (
                "nafaka",
                "yoksulluk nafakasi",
                "tmk 176",
                "tmk 175",
                "hakkaniyet",
                "mali durum",
                "odeme gucu",
                "ayipli arac",
                "gizli ayip",
                "ayiba karsi tekefful",
                "sozlesmeden donme",
                "bedel indirimi",
                "tramer",
                "ekspertiz",
                "tbk 219",
                "tbk 223",
                "tbk 227",
                "tbk 229",
                "tkhk",
            )
        )

    @staticmethod
    def _matching_doctrine_principle(*, query: str, practice_area: str | None) -> str:
        cards = book_memory_service.search_doctrine_cards(
            query=query,
            practice_area=practice_area,
            max_results=1,
        )
        return cards[0].get("principle", "") if cards else ""

    @staticmethod
    def _statute_sources(*, case_text: str, topic: str) -> list[StatuteSource]:
        combined = LegalRetrievalService._plain(f"{case_text} {topic}")
        sources: list[StatuteSource] = []
        if "nafaka" in combined:
            sources.extend(
                [
                    StatuteSource(code="TMK", article="175", relevance="Yoksulluk nafakasının koşulları bakımından temel kanuni dayanak olarak değerlendirilir."),
                    StatuteSource(code="TMK", article="176/3", relevance="Yoksulluk nafakasının kaldırılması ve sona ermesi bakımından değerlendirilir."),
                    StatuteSource(code="TMK", article="176/4", relevance="Tarafların mali durumlarının değişmesi ve hakkaniyet nedeniyle nafakanın artırılması, azaltılması veya kaldırılması bakımından uygulanır."),
                    StatuteSource(code="TMK", article="4", relevance="Hakkaniyet değerlendirmesinin genel dayanağıdır."),
                ]
            )
        if LegalRetrievalService._is_vehicle_query(combined):
            sources.extend(
                [
                    StatuteSource(code="TBK", article="219", relevance="Satılanın alıcıya bildirilen veya beklenen nitelikleri taşımaması halinde ayıp sorumluluğunun temel dayanağıdır."),
                    StatuteSource(code="TBK", article="223", relevance="Ayıbın gözden geçirilmesi ve satıcıya bildirilmesi bakımından değerlendirilir."),
                    StatuteSource(code="TBK", article="227", relevance="Alıcının sözleşmeden dönme, bedel indirimi, ücretsiz onarım ve benzeri seçimlik hakları bakımından uygulanır."),
                    StatuteSource(code="TBK", article="229", relevance="Sözleşmeden dönmenin sonuçları, satış bedelinin iadesi ve bağlı zarar kalemleri bakımından dikkate alınır."),
                    StatuteSource(code="TKHK", article="ayıplı mal hükümleri", relevance="Satıcının galeri, şirket veya tacir olduğu tüketici işlemlerinde ayıplı mal hükümleri ayrıca değerlendirilmelidir."),
                    StatuteSource(code="HMK", article="190 ve 266", relevance="İspat yükü ve teknik ayıp/değer farkı için bilirkişi incelemesi bakımından önemlidir."),
                ]
            )
        return sources

    @staticmethod
    def _article_label(metadata: dict[str, Any]) -> str:
        code = metadata.get("code") or ""
        article = metadata.get("article") or ""
        if code and article:
            return f"{code} {article}"
        return str(article or "")

    @staticmethod
    def _is_blocked_result(payload: dict[str, Any], blocked_terms: list[str]) -> bool:
        if not blocked_terms:
            return False
        haystack = LegalRetrievalService._plain(" ".join(str(value or "") for value in payload.values()))
        return any(term and term in haystack for term in blocked_terms)

    @staticmethod
    def _default_practice_area(topic: str) -> str:
        plain_topic = LegalRetrievalService._plain(topic)
        if "nafaka" in plain_topic:
            return "Aile Hukuku"
        if LegalRetrievalService._is_vehicle_query(plain_topic):
            return "Borçlar Hukuku"
        return "Genel Hukuk"

    @staticmethod
    def _preview(text: str) -> str:
        normalized = " ".join(str(text or "").split())
        if len(normalized) <= 800:
            return normalized
        return f"{normalized[:797].rstrip()}..."

    @staticmethod
    def _dedupe(values: list[str]) -> list[str]:
        result: list[str] = []
        seen: set[str] = set()
        for value in values:
            key = value.casefold()
            if value and key not in seen:
                seen.add(key)
                result.append(value)
        return result

    @staticmethod
    def _plain(text: str) -> str:
        translation = str.maketrans(
            {
                "ç": "c",
                "Ç": "c",
                "ğ": "g",
                "Ğ": "g",
                "ı": "i",
                "I": "i",
                "İ": "i",
                "ö": "o",
                "Ö": "o",
                "ş": "s",
                "Ş": "s",
                "ü": "u",
                "Ü": "u",
            }
        )
        return " ".join(text.translate(translation).casefold().split())


legal_retrieval_service = LegalRetrievalService()
