"""Legal Brain retrieval workflows."""

from __future__ import annotations

import re
from typing import Any

from app.models.legal_brain_models import (
    DoctrineCard,
    LegalBrainRetrieveForCaseResponse,
    LegalBrainSearchResponse,
    LegalBrainSearchResult,
    StatuteSource,
)
from app.services.book_memory_service import book_memory_service
from app.services.case_analyzer import case_analyzer
from app.services.legal_argument_builder import legal_argument_builder
from app.services.legal_embedding_service import legal_embedding_service


ARTICLE_REF_RE = re.compile(r"\b(TMK|HMK|TBK|TKHK)\s*(?:m\.?|madde)?\s*(\d{1,4})(?:/\d+)?", flags=re.IGNORECASE)

EXACT_PHRASES: tuple[tuple[str, str], ...] = (
    ("yoksulluk nafakası", "yoksulluk nafakasi"),
    ("nafakanın kaldırılması", "nafakanin kaldirilmasi"),
    ("nafakanın indirilmesi", "nafakanin indirilmesi"),
    ("nafaka indirimi", "nafaka indirimi"),
    ("sosyal ve ekonomik durum", "sosyal ve ekonomik durum"),
    ("mali durum", "mali durum"),
    ("ödeme gücü", "odeme gucu"),
    ("emekli maaşı", "emekli maasi"),
    ("kira", "kira"),
    ("hakkaniyet", "hakkaniyet"),
    ("ayıplı araç", "ayipli arac"),
    ("gizli ayıp", "gizli ayip"),
    ("ayıba karşı tekeffül", "ayiba karsi tekefful"),
    ("sözleşmeden dönme", "sozlesmeden donme"),
    ("bedel indirimi", "bedel indirimi"),
    ("TRAMER", "tramer"),
    ("ekspertiz raporu", "ekspertiz raporu"),
    ("noter satış sözleşmesi", "noter satis sozlesmesi"),
    ("TBK 219", "tbk 219"),
    ("TBK 223", "tbk 223"),
    ("TBK 227", "tbk 227"),
    ("TBK 229", "tbk 229"),
)

MATCH_TERMS: tuple[tuple[str, str], ...] = (
    ("nafaka", "nafaka"),
    ("yoksulluk nafakası", "yoksulluk nafakasi"),
    ("nafakanın kaldırılması", "nafakanin kaldirilmasi"),
    ("nafakanın indirilmesi", "nafakanin indirilmesi"),
    ("TMK 176", "tmk 176"),
    ("TMK 175", "tmk 175"),
    ("hakkaniyet", "hakkaniyet"),
    ("mali durum", "mali durum"),
    ("sosyal ve ekonomik durum", "sosyal ve ekonomik durum"),
    ("ödeme gücü", "odeme gucu"),
    ("kira", "kira"),
    ("emekli maaşı", "emekli maasi"),
    ("ispat", "ispat"),
    ("ayıplı araç", "ayipli arac"),
    ("gizli ayıp", "gizli ayip"),
    ("araç satışı", "arac satisi"),
    ("ikinci el araç", "ikinci el arac"),
    ("ayıba karşı tekeffül", "ayiba karsi tekefful"),
    ("sözleşmeden dönme", "sozlesmeden donme"),
    ("bedel indirimi", "bedel indirimi"),
    ("TRAMER", "tramer"),
    ("ekspertiz raporu", "ekspertiz raporu"),
    ("servis raporu", "servis raporu"),
    ("noter satış sözleşmesi", "noter satis sozlesmesi"),
    ("TBK 219", "tbk 219"),
    ("TBK 223", "tbk 223"),
    ("TBK 227", "tbk 227"),
    ("TBK 229", "tbk 229"),
    ("TKHK", "tkhk"),
    ("bilirkişi", "bilirkisi"),
)

IRRELEVANT_AREA_TERMS = (
    "vesayet",
    "mulkiyet",
    "mülkiyet",
    "evlat edinme",
    "miras",
    "zilyetlik",
    "irtifak",
    "soybag",
    "soybağı",
    "tapu",
    "bosanma",
    "boşanma",
    "velayet",
    "istirak nafakasi",
    "iştirak nafakası",
    "yoksulluk nafakasi",
    "yoksulluk nafakası",
)

GENERIC_QUERY_TOKENS = {
    "kaldirilmasi",
    "kaldırılması",
    "indirilmesi",
    "durum",
    "madde",
    "talep",
    "odeme",
    "ödeme",
    "gucu",
    "gücü",
    "olan",
    "icin",
