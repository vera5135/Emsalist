"""Case enrichment agent with Gemini support and deterministic fallback."""

from __future__ import annotations

import json
import re
from typing import Any

from pydantic import ValidationError

from app.models.ai_models import CaseEnrichmentResponse
from app.services.ai_output_validator import ai_output_validator
from app.services.case_analyzer import case_analyzer
from app.services.gemini_client import gemini_client


VEHICLE_YARGITAY_QUERIES = [
    '"ayıplı araç" "gizli ayıp"',
    '"ikinci el araç" "gizli ayıp"',
    '"ayıplı araç" "sözleşmeden dönme"',
    '"araç satışı" "bedel indirimi"',
    '"ayıplı araç" "servis raporu"',
    '"gizli ayıp" "ayıp ihbarı"',
]

VEHICLE_SEARCH_KEYWORDS = [
    "ayıplı araç",
    "gizli ayıp",
    "ikinci el araç satışı",
    "satıcının ayıba karşı sorumluluğu",
    "ayıp ihbarı",
    "sözleşmeden dönme",
    "bedel indirimi",
    "TRAMER",
    "hasar kaydı",
    "ekspertiz raporu",
    "servis raporu",
    "motor arızası",
    "noter satış sözleşmesi",
]

VEHICLE_LEGAL_THEORY = [
    "satıcının ayıba karşı sorumluluğu",
    "gizli ayıp",
    "ayıp ihbarı",
    "seçimlik haklar",
    "sözleşmeden dönme",
    "bedel indirimi",
    "zarar kalemlerinin tahsili",
]

VEHICLE_BLOCKED_TOPICS = ["nafaka", "TMK 175", "TMK 176", "boşanma", "velayet", "miras", "aile hukuku"]
VEHICLE_ARTICLES = ["TBK 219", "TBK 223", "TBK 227", "TBK 229"]
VEHICLE_LEGAL_BRAIN_QUERY = (
    "TBK 219 TBK 223 TBK 227 TBK 229 TKHK ayıplı araç gizli ayıp satıcının ayıba karşı sorumluluğu "
    "ayıp ihbarı seçimlik haklar sözleşmeden dönme bedel indirimi ekspertiz TRAMER servis raporu"
)


class CaseEnrichmentAgent:
    def enrich(self, *, case_text: str, practice_area: str | None, use_gemini: bool = True) -> CaseEnrichmentResponse:
        fallback = self._fallback(case_text=case_text, practice_area=practice_area)
        gemini_result = gemini_client.generate_json(
            system_instruction=self._system_instruction(),
            prompt=self._prompt(case_text=case_text, practice_area=practice_area),
            fallback=fallback.model_dump(),
            use_gemini=use_gemini,
        )
        if not gemini_result.ai_used:
            fallback.warnings.extend(gemini_result.warnings)
            return fallback

        try:
            response = self._sanitize_response(gemini_result.data, original_case_text=case_text)
            response.ai_used = True
            response.warnings.extend(gemini_result.warnings)
            return response
        except (ValidationError, TypeError, ValueError):
            fallback.warnings.extend(["Gemini enrich-case çıktısı validator’dan geçmedi; fallback kullanıldı."])
            return fallback

    def _fallback(self, *, case_text: str, practice_area: str | None) -> CaseEnrichmentResponse:
        analysis = case_analyzer.analyze(case_text)
        facts = self._sentences(case_text)
        plain = ai_output_validator.plain(case_text)
        if ai_output_validator.is_vehicle_case(case_text):
            missing = self._vehicle_missing_facts(plain)
            inferred = []
            if any(term in plain for term in ("galeri", "sirket", "tacir")):
                inferred.append("Satıcının profesyonel/tacir sıfatı nedeniyle tüketici işlemi ve Tüketici Mahkemesi görevi değerlendirilebilir.")
            return CaseEnrichmentResponse(
                ai_used=False,
                original_case_text=case_text,
                enriched_case_text=self._enriched_text(case_text, VEHICLE_LEGAL_THEORY),
                detected_practice_area="Tüketici Hukuku / Borçlar Hukuku",
                detected_case_type="gizli ayıplı ikinci el araç satışı",
                legal_theory=VEHICLE_LEGAL_THEORY,
                confirmed_facts=facts,
                inferred_facts=inferred,
                missing_facts=missing,
                critical_questions=self._vehicle_questions(),
                search_keywords=VEHICLE_SEARCH_KEYWORDS,
                yargitay_query_templates=VEHICLE_YARGITAY_QUERIES,
                legal_brain_query=VEHICLE_LEGAL_BRAIN_QUERY,
                relevant_codes=["TBK", "TKHK", "HMK"],
                relevant_articles=VEHICLE_ARTICLES,
                blocked_topics=VEHICLE_BLOCKED_TOPICS,
                risk_flags=[
                    "Ayıp ihbarının süresi ve yöntemi ispatlanmalıdır.",
                    "Ayıbın satıştan önce mevcut olduğu teknik raporla desteklenmelidir.",
                    "Satıcının sıfatı görevli mahkeme bakımından kontrol edilmelidir.",
                ],
                petition_strategy_hint="Öncelikle sözleşmeden dönme ve satış bedelinin iadesi, aksi halde bedel indirimi ve zarar kalemleri terditli kurulmalıdır.",
                confidence=86,
                warnings=[],
            )

        return CaseEnrichmentResponse(
            ai_used=False,
            original_case_text=case_text,
            enriched_case_text=case_text,
            detected_practice_area=practice_area if practice_area and practice_area != "auto" else "Genel Hukuk",
            detected_case_type=analysis.legal_topic,
            legal_theory=analysis.legal_keywords[:8],
            confirmed_facts=facts or analysis.case_facts,
            inferred_facts=[],
            missing_facts=["Talep sonucu, tarih, taraf sıfatı ve deliller somutlaştırılmalıdır."],
            critical_questions=[
                "Somut talep nedir?",
                "Talebi destekleyen belgeler nelerdir?",
                "Karşı tarafın beklenen savunması nedir?",
            ],
            search_keywords=analysis.legal_keywords,
            yargitay_query_templates=[],
            legal_brain_query=" ".join([case_text, analysis.legal_topic, *analysis.legal_keywords]),
            relevant_codes=[],
            relevant_articles=[],
            blocked_topics=[],
            risk_flags=[],
            petition_strategy_hint="Olay, delil, hukuki neden ve talep sonucu bağlantısı açık kurulmalıdır.",
            confidence=55,
            warnings=[],
        )

    def _sanitize_response(self, data: dict[str, Any], *, original_case_text: str) -> CaseEnrichmentResponse:
        fallback = self._fallback(case_text=original_case_text, practice_area=data.get("detected_practice_area") or "auto")
        merged = fallback.model_dump()
        for key in (
            "enriched_case_text",
            "detected_practice_area",
            "detected_case_type",
            "legal_brain_query",
            "petition_strategy_hint",
        ):
            if isinstance(data.get(key), str) and data[key].strip():
                merged[key] = " ".join(data[key].split())

        for key in (
            "legal_theory",
            "confirmed_facts",
            "inferred_facts",
            "missing_facts",
            "critical_questions",
            "search_keywords",
            "yargitay_query_templates",
            "relevant_codes",
            "relevant_articles",
            "blocked_topics",
            "risk_flags",
        ):
            merged[key] = ai_output_validator.clean_ai_list(data.get(key), max_items=30) or merged[key]

        merged["original_case_text"] = original_case_text
        merged["confidence"] = self._bounded_int(data.get("confidence"), fallback.confidence)
        merged["warnings"] = ai_output_validator.clean_ai_list(data.get("warnings"), max_items=20)
        return CaseEnrichmentResponse(**merged)

    @staticmethod
    def _system_instruction() -> str:
        return (
            "Sen Emsalist içinde çalışan kontrollü bir hukuki analiz ajanısın. Sadece JSON döndür. "
            "Yeni vakıa, Yargıtay kararı, esas/karar numarası, kaynak, sayfa veya kanun maddesi uydurma. "
            "confirmed_facts sadece kullanıcının açıkça yazdığı vakıaları içersin."
        )

    @staticmethod
    def _prompt(*, case_text: str, practice_area: str | None) -> str:
        schema = {
            "ai_used": True,
            "original_case_text": case_text,
            "enriched_case_text": "",
            "detected_practice_area": "",
            "detected_case_type": "",
            "legal_theory": [],
            "confirmed_facts": [],
            "inferred_facts": [],
            "missing_facts": [],
            "critical_questions": [],
            "search_keywords": [],
            "yargitay_query_templates": [],
            "legal_brain_query": "",
            "relevant_codes": [],
            "relevant_articles": [],
            "blocked_topics": [],
            "risk_flags": [],
            "petition_strategy_hint": "",
            "confidence": 0,
            "warnings": [],
        }
        return (
            "Aşağıdaki olay metnini Emsalist için yapılandırılmış hukuki JSON'a dönüştür.\n"
            f"Alan: {practice_area or 'auto'}\n"
            f"JSON şeması: {json.dumps(schema, ensure_ascii=False)}\n"
            f"Olay metni: {case_text}"
        )

    @staticmethod
    def _enriched_text(case_text: str, legal_theory: list[str]) -> str:
        return " ".join(str(case_text or "").split())

    @staticmethod
    def _sentences(case_text: str) -> list[str]:
        return [
            sentence.strip(" -\t")
            for sentence in re.split(r"(?<=[.!?])\s+|[;\n]+", " ".join(case_text.split()))
            if sentence.strip()
        ][:12]

    @staticmethod
    def _vehicle_missing_facts(plain_text: str) -> list[str]:
        checks = [
            ("Satış tarihi açık yazılmalı.", ("satis tarihi", "tarihinde")),
            ("Satış bedelinin miktarı yazılmalı.", ("tl", "lira", "bedel miktari")),
            ("Araç marka-model, plaka ve şasi bilgisi yazılmalı.", ("plaka", "sasi", "marka")),
            ("Servis/ekspertiz rapor tarihi ve rapor numarası belirtilmeli.", ("rapor tarihi", "rapor no")),
            ("TRAMER/hasar kaydının tarihi ve içeriği somutlaştırılmalı.", ("tramer", "hasar kaydi")),
            ("Noter ihtarnamesi tarihi ve tebliğ bilgisi eklenmeli.", ("ihtar tarihi", "teblig")),
        ]
        missing = [message for message, terms in checks if not any(term in plain_text for term in terms)]
        return missing

    @staticmethod
    def _vehicle_questions() -> list[str]:
        return [
            "Satıcı galeri/şirket/tacir mi, gerçek kişi mi?",
            "Aracın marka-modeli, plaka/şasi bilgisi, satış tarihi ve satış bedeli nedir?",
            "Noter satış sözleşmesi, ödeme dekontu ve ilan/yazışma kayıtları var mı?",
            "Motor arızası, gizli onarım, TRAMER veya hasar kaydı hangi raporla tespit edildi?",
            "Ayıp olağan gözden geçirme ile fark edilebilir miydi?",
            "Ayıp hangi tarihte öğrenildi, satıcıya hangi tarihte ve hangi yolla bildirildi?",
            "Öncelikli seçimlik hak sözleşmeden dönme mi, bedel indirimi mi?",
            "Onarım, ekspertiz, servis, ihtarname ve değer kaybı zararları nelerdir?",
        ]

    @staticmethod
    def _bounded_int(value: Any, default: int) -> int:
        try:
            return max(0, min(100, int(value)))
        except (TypeError, ValueError):
            return default


case_enrichment_agent = CaseEnrichmentAgent()
