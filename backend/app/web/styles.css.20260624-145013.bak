:root {
  color-scheme: light;
  --bg: #f5f7f8;
  --surface: #ffffff;
  --surface-2: #eef4f2;
  --text: #17211d;
  --muted: #62706b;
  --line: #d9e2df;
  --accent: #0f766e;
  --accent-2: #1d4ed8;
  --danger: #b42318;
  --shadow: 0 18px 48px rgba(23, 33, 29, 0.08);
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-width: 320px;
  background:
    linear-gradient(180deg, rgba(15, 118, 110, 0.08), rgba(245, 247, 248, 0) 260px),
    var(--bg);
  color: var(--text);
  font-family:
    Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 15px;
}

button,
input,
select,
textarea {
  font: inherit;
}

button,
a {
  -webkit-tap-highlight-color: transparent;
}

.topbar {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  min-height: 72px;
  padding: 12px clamp(16px, 4vw, 48px);
  border-bottom: 1px solid rgba(217, 226, 223, 0.86);
  background: rgba(245, 247, 248, 0.86);
  backdrop-filter: blur(14px);
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  color: inherit;
  text-decoration: none;
}

.brand-mark {
  display: grid;
  width: 42px;
  height: 42px;
  place-items: center;
  border: 1px solid rgba(15, 118, 110, 0.28);
  border-radius: 8px;
  background: #0f766e;
  color: white;
  font-weight: 800;
  box-shadow: var(--shadow);
}

.brand strong,
.brand small {
  display: block;
  line-height: 1.1;
}

.brand small {
  margin-top: 3px;
  color: var(--muted);
  font-size: 12px;
}

.top-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
  flex-wrap: wrap;
}

.top-actions a,
.status-pill {
  min-height: 34px;
  display: inline-flex;
  align-items: center;
  border-radius: 8px;
  padding: 0 12px;
  border: 1px solid var(--line);
  background: var(--surface);
  color: var(--text);
  text-decoration: none;
  font-size: 13px;
}

.status-pill.ok {
  border-color: rgba(15, 118, 110, 0.22);
  background: rgba(15, 118, 110, 0.1);
  color: #0b5d56;
}

.status-pill.bad {
  border-color: rgba(180, 35, 24, 0.24);
  background: rgba(180, 35, 24, 0.08);
  color: var(--danger);
}

.app-shell {
  width: min(1420px, calc(100% - 32px));
  margin: 24px auto 48px;
}

.search-band {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 360px;
  gap: 16px;
  align-items: stretch;
}

.search-box,
.quick-panel,
.result-column,
.draft-panel {
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--surface);
  box-shadow: var(--shadow);
}

.search-box {
  padding: 18px;
}

label {
  display: grid;
  gap: 7px;
  color: var(--muted);
  font-size: 13px;
  font-weight: 700;
}

textarea,
input,
select {
  width: 100%;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: #fbfcfc;
  color: var(--text);
  outline: none;
  transition:
    border-color 0.15s ease,
    box-shadow 0.15s ease,
    background 0.15s ease;
}

textarea {
  min-height: 164px;
  resize: vertical;
  padding: 15px;
  line-height: 1.5;
  font-size: 16px;
}

input,
select {
  height: 42px;
  padding: 0 12px;
}

textarea:focus,
input:focus,
select:focus {
  border-color: rgba(15, 118, 110, 0.62);
  background: #ffffff;
  box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.12);
}

.search-controls {
  display: grid;
  grid-template-columns: minmax(160px, 1fr) 108px auto;
  gap: 10px;
  margin-top: 14px;
  align-items: end;
}

.quick-panel {
  display: grid;
  gap: 12px;
  padding: 16px;
}

.panel-title,
.section-head,
.draft-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.panel-title {
  color: var(--text);
  font-weight: 800;
}

.panel-actions {
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.small-btn {
  min-height: 34px;
  padding: 0 10px;
  font-size: 13px;
}

.strategy-output {
  display: none;
  border: 1px solid rgba(29, 78, 216, 0.14);
  border-radius: 8px;
  padding: 10px;
  background: rgba(29, 78, 216, 0.06);
  color: #1f3d7a;
  font-size: 13px;
  line-height: 1.45;
}

.strategy-output.active {
  display: block;
}

.question-fields {
  display: grid;
  gap: 10px;
}

.question-empty {
  min-height: 72px;
  display: grid;
  place-items: center;
  border: 1px dashed var(--line);
  border-radius: 8px;
  color: var(--muted);
  text-align: center;
  font-size: 13px;
}

.question-card {
  display: grid;
  gap: 8px;
}

.question-card textarea {
  min-height: 74px;
  padding: 10px;
  font-size: 14px;
}

.answer-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.answer-chip {
  min-height: 30px;
  max-width: 100%;
  border-color: rgba(15, 118, 110, 0.18);
  border-radius: 999px;
  padding: 0 10px;
  background: #f7fbfa;
  color: #31554d;
  font-size: 12px;
  font-weight: 800;
  white-space: normal;
  text-align: left;
}

.answer-chip:hover,
.answer-chip.selected {
  background: rgba(15, 118, 110, 0.1);
  color: #0b5d56;
  transform: none;
}

.toolbar {
  display: flex;
  gap: 10px;
  margin: 16px 0 12px;
  flex-wrap: wrap;
}

button {
  min-height: 42px;
  border: 1px solid rgba(15, 118, 110, 0.28);
  border-radius: 8px;
  padding: 0 15px;
  background: var(--surface);
  color: var(--text);
  cursor: pointer;
  font-weight: 800;
  transition:
    transform 0.12s ease,
    border-color 0.12s ease,
    background 0.12s ease;
}

button:hover {
  transform: translateY(-1px);
  border-color: rgba(15, 118, 110, 0.55);
  background: var(--surface-2);
}

button:disabled {
  cursor: wait;
  opacity: 0.64;
  transform: none;
}

.primary-btn {
  background: var(--accent);
  color: white;
}

.primary-btn:hover {
  background: #0b5d56;
}

.ghost-btn {
  border-color: var(--line);
  color: var(--muted);
}

.icon-btn {
  width: 34px;
  min-height: 34px;
  padding: 0;
  font-size: 22px;
  line-height: 1;
}

.status-line {
  min-height: 24px;
  margin: 4px 0 14px;
  color: var(--muted);
  font-weight: 700;
}

.status-line.error {
  color: var(--danger);
}

.results-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr) minmax(0, 1.35fr);
  gap: 16px;
  align-items: start;
}

.result-column,
.draft-panel {
  overflow: hidden;
}

.section-head {
  min-height: 56px;
  padding: 0 16px;
  border-bottom: 1px solid var(--line);
  background: #fbfcfc;
}

.section-head h2 {
  margin: 0;
  font-size: 16px;
}

.section-head span {
  min-width: 28px;
  height: 28px;
  display: inline-grid;
  place-items: center;
  border-radius: 999px;
  background: var(--surface-2);
  color: var(--muted);
  font-weight: 800;
  font-size: 12px;
}

.empty-state,
.result-list,
#draftOutput {
  padding: 16px;
}

.empty-state {
  min-height: 132px;
  display: grid;
  place-items: center;
  color: var(--muted);
  text-align: center;
}

.result-list {
  display: grid;
  gap: 12px;
  max-height: 520px;
  overflow: auto;
}

.result-item {
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 13px;
  background: #ffffff;
}

.result-item h3 {
  margin: 0 0 8px;
  font-size: 14px;
  line-height: 1.35;
}

.meta-row {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 8px;
}

.chip {
  display: inline-flex;
  align-items: center;
  min-height: 24px;
  border-radius: 999px;
  padding: 0 8px;
  background: #eef4f2;
  color: #31554d;
  font-size: 12px;
  font-weight: 800;
}

.chip.blue {
  background: rgba(29, 78, 216, 0.1);
  color: var(--accent-2);
}

.result-item p,
.compact-list {
  margin: 0;
  color: #32443e;
  line-height: 1.48;
}

.compact-list {
  display: grid;
  gap: 8px;
  padding-left: 18px;
}

.compact-list li::marker {
  color: var(--accent);
}

.draft-panel {
  margin-top: 16px;
}

#draftOutput {
  min-height: 280px;
  max-height: 620px;
  overflow: auto;
  margin: 0;
  white-space: pre-wrap;
  color: #22312c;
  line-height: 1.55;
  font-family: "Consolas", "Courier New", monospace;
  font-size: 14px;
}

@media (max-width: 1080px) {
  .search-band,
  .results-grid {
    grid-template-columns: 1fr;
  }

  .result-list {
    max-height: none;
  }
}

@media (max-width: 680px) {
  .topbar {
    align-items: flex-start;
    flex-direction: column;
  }

  .top-actions {
    justify-content: flex-start;
  }

  .app-shell {
    width: min(100% - 20px, 1420px);
    margin-top: 14px;
  }

  .search-controls {
    grid-template-columns: 1fr;
  }

  .toolbar button {
    flex: 1 1 145px;
  }
}
